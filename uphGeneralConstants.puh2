#define CON_FLT_UNSTABLE_CURR_LOOP_DETECTED                             1071                        //"Unstable current loop detected"
#define CON_FLT_HIGH_PIV_NOISE_DETECTED                                 1072                        //"High noise/jitter detected"
#define CON_FLT_NO_PHASING_IS_DETECTED									1080						//"No phasing is detected"
#define CON_FLT_CPU_BG_WATCHDOG											1081						//"CPU background loop watchdog timeout"

