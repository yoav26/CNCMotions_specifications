// Controller Fault (ConFlt) definitions and bits
//remvoe-#define	CON_FLT_NONE													0							//"No fault has occurred"
//remvoe-#define CON_FLT_BASE                                                    1000                        //Base from which ConFlt is incremented
#define	CON_FLT_ABORT													1001						//"Abort signal was detected"
#define	CON_FLT_SHORT													1002						//"Short from motor phase to ground"
#define	CON_FLT_ENCODER_ERROR											1003						//"Encoder error (disconnected or other errors)"
#define	CON_FLT_WATCH_DOG												1004						//"FPGA watchdog not received"
#define	CON_FLT_DEAD_TIME												1005						//"PWM dead time too short"
#define	CON_FLT_HALLS_DISCONNECTED										1006						//"Hall input disconnected"
#define	CON_FLT_MOTOR_STUCK												1007						//"Motor is stuck"
#define	CON_FLT_BUS_OVER_VOLTAGE										1008						//"Bus Voltage too high"
#define	CON_FLT_BUS_UNDER_VOLTAGE										1009						//"Bus Voltage too low"
#define	CON_FLT_LOGIC_OVER_VOLTAGE										1010						//"Logic Voltage too high"
#define	CON_FLT_LOGIC_UNDER_VOLTAGE										1011						//"Logic Voltage too low"
#define	CON_FLT_HIGH_BUS_CURRENT										1012						//"Bus current too high"
#define	CON_FLT_PHASE_A_CURRENT											1013						//"Phase A current too high"
#define	CON_FLT_PHASE_B_CURRENT											1014						//"Phase B current too high"
#define	CON_FLT_PHASE_C_CURRENT											1015						//"Phase C current too high"
#define	CON_FLT_MOTOR_CURRENT											1016						//"Motor current too high"
#define	CON_FLT_OVER_DRIVER_POWER										1017						//"Driver power exceeds limit"
#define	CON_FLT_HIGH_IPM_TEMP											1018						//"IPM temperature too high"
#define	CON_FLT_HIGH_VELOCITY											1019						//"Velocity too high"
#define	CON_FLT_HIGH_POS_ERR											1020						//"Position error exceeds limit"
#define	CON_FLT_HIGH_VEL_ERR											1021						//"Velocity error exceeds limit"
#define	CON_FLT_HIGH_CPU_TEMP											1022						//"CPU temperature too high"
#define	CON_FLT_BUS_OVER_VOLTAGE_ABS									1023						//"Bus Voltage too high - exceed absolute limitation"
#define	CON_FLT_STO1													1024						//"STO1 activated"
#define	CON_FLT_OVERCURR_A												1025						//"Over current detected on motor A"
#define	CON_FLT_AUX_ENC_ERROR											1026						//"Auxiliary encoder error (disconnected or other errors)"
#define	CON_FLT_IPM_FAULT												1027						//"IPM fault"
#define	CON_FLT_UNKNOWN_ENCODER_TYPE									1028						//"The selected encoder type is currently not supported"
#define	CON_FLT_UNKNOWN_AUX_ENCODER_TYPE								1029						//"The selected auxiliary encoder type is currently not supported"
#define	CON_FLT_ECAM_MASTER_TOO_FAST									1030						//"The ECAM master variables changed more than 1 ECAM cycle in 1 sample"
#define	CON_FLT_FIFO_TOO_SMALL_ACCLERATION								1031						//"The FIFO reached a motion segment which results with a too small acceleration: below 1/Ts"
#define	CON_FLT_IMPROPER_MODULUS_USAGE									1032						//"The main encoder modulus can't be used with input shaping feature"
#define	CON_FLT_BIT_FAILED												1033						//"Some fault was detected during power on BIT. Use BITFault to read its code"
#define	CON_FLT_STO2_OR_VCC_DRIVE										1034						//"STO2 activated or problem with Vcc of amplifier"
#define	CON_FLT_CONTROL_AC_POWER_CUTOFF									1035						//"AC Power supply to the control was cut off"
#define	CON_FLT_OVERCURR_B												1036						//"Over current detected on motor B"
#define	CON_FLT_LINEAR_AMPLIFIER_OVER_CURR_CONT							1037						//"Over continuous current detected on built-in Linear Amplifier"
#define	CON_FLT_LINEAR_AMPLIFIER_OVER_VOLTAGE							1038						//"Over voltage detected by the built-in Linear Amplifier"
#define	CON_FLT_LINEAR_PWM_AMPLIFIER_CONFLICT							1039						//"AAmpType and BAmpType have conflicting values. Can not be one Linear and one PWM"
#define	CON_FLT_HIGH_MOTOR_TEMP											1040						//"Motor temperature too high"
#define	CON_FLT_RESERVED1												1041						//"Unexpected error code, consult Agito"
#define	CON_FLT_5V_ISO													1042						//"Amplifier isolated 5v fault"
#define CON_FLT_CI_DISCONNECTED											1043						//"CI Communication was disconnected"
#define CON_FLT_MOTOR_I2T                                               1044                        //"Motor current over I2T"
#define CON_FLT_HIGH_FORCE_ERR                                          1045                        //"Force error exceeds limit"
#define CON_FLT_NO_FORCE_FEEDBACK										1046						//"Force control: analog force feedback not defined"
#define CON_FLT_5V_FAULT												1047						//"One of the 5v output pins for encoders or I/O activated the current limitation. Check your HW connections!"
#define CON_FLT_MEMBER_UNEXPECTED_MOTOR_OFF								1048						//"Other member axis got motor off"
#define	CON_FLT_DUAL_STUCK												1049						//"Dual Loop high difference between velocities"
#define	CON_FLT_FAULT_INPUT												1050						//"External fault input (for example: of external drive) is activated"
#define	CON_FLT_INRUSH_RESISTOR											1051						//"Internal relay is still switched off. Try waiting more time after power on before enabling the motor"
#define	CON_FLT_STO2													1052						//"STO2 activated"
#define	CON_FLT_AMP_TYPE_ERROR											1053						//"AmpType value not allowed for this product"
#define	CON_FLT_MOTOR_AC_POWER_CUTOFF									1054						//"At least one required phase of the AC Power inputs was cut off"
#define CON_FLT_HIGH_POS_ERR_OL                                         1055                        //"Position error exceeds limit in open-loop"
#define CON_FLT_HIGH_VEL_ERR_OL                                         1056                        //"Velocity error exceeds limit in open-loop"
#define CON_FLT_HIGH_FORCE_ERR_OL                                       1057                        //"Force error exceeds limit in open-loop"
#define CON_FLT_UNDERVOLTAGE                                            1058                        //"Undervoltage detected on 10.5v supply (8v threshold)"
#define CON_FLT_OVERCURR_C                                              1059                        //"Over current detected on motor C"
#define	CON_FLT_HIGH_BOARD_TEMP											1060						//"Product temperature (BoardTemp) too high"
#define CON_FLT_GANTRY_MEMBER_UNEXPECTED_MOTOR_OFF						1061						//"Other gantry member axis got motor off"
#define	CON_FLT_FAULT_INPUT_CONTROLLED_STOP								1062						//"External request to Fault with Controlled Stop: stop ended and motor was disabled"
#define CON_FLT_VEC_MEMBER_UNEXPECTED_MOTOR_OFF							1063						//"Other member axis got motor off"
#define CON_FLT_ICNQC_ERROR												1064						//"There is an error in the encoder sine/cosine reading."
#define CON_FLT_STALL_DETECTED_AND_MOTOR_OFF							1065						//"Stall detection activated, motor is turning off"
#define CON_FLT_VENC_MAX_NUM_PULSES_EXCEEDED                            1066                        //"Virtual encoder has exceeded the max number of possible pulses per interrupt"
#define CON_FLT_ANOMALY_DETECTED										1067                        //"Anomaly/collision detected in the system"
#define CON_FLT_ABS_ENC_ERROR                                           1068                        //"Abs Encoder Error bit is asserted, either the assembly encoder readhead is not good, or the encoder scale needs to be inspected"
#define CON_FLT_ABS_ENC_CRC_ERR                                         1069                        //"Abs Encoder CRC has failed beyond a time threshold set by EncAbsErrTime. The noise level might be too high"
