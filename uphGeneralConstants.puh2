/*
// Motion mode (glMotionMode) definitions and bits
#define	MOTION_MODE_INVALID												-1
#define	MOTION_MODE_JOG													0	// Indirect (Speed set in this mode, not directly by user)
#define	MOTION_MODE_PTP													1	// Indirect (Speed set in this mode, not directly by user)
#define	MOTION_MODE_PTP_REP												2	// Indirect (Speed set in this mode, not directly by user)
#define	MOTION_MODE_PD_DIRECT											3	// Direct 	(Speed set directly by user through their position commands)
#define	MOTION_MODE_PD_INDIRECT											4	// Indirect (Speed set in this mode, not directly by user)
#define	MOTION_MODE_GEAR_DIRECT											5	// Direct 	(Speed set directly by user through their position commands)
#define	MOTION_MODE_GEAR_INDIRECT										6	// Indirect (Speed set in this mode, not directly by user)
#define	MOTION_MODE_ECAM_DIRECT											7	// Direct 	(Speed set directly by user through their position commands)
#define	MOTION_MODE_ECAM_INDIRECT										8	// Indirect (Speed set in this mode, not directly by user)
#define	MOTION_MODE_FIFO												9	// Direct 	(Speed set directly by user through their position commands)
#define	MOTION_MODE_SLAVE_POSREF										10	// Direct 	(Speed set directly by user through their position commands)
#define	MOTION_MODE_CNCA												11	// Direct 	(Speed set directly by user through their position commands (Per axis))
#define	MOTION_MODE_JOYSTICK_POS_DIRECT									12	// Direct 	(Speed set directly by user through their position commands)
#define	MOTION_MODE_JOYSTICK_POS_INDIRECT								13	// Indirect (Speed set in this mode, not directly by user)
#define	MOTION_MODE_JOYSTICK_VEL_DIRECT									14	// Direct 	(Speed set directly by user through their velocity commands)
#define	MOTION_MODE_JOYSTICK_VEL_INDIRECT								15	// Direct 	(Speed set directly by user through their velocity commands)
#define	MOTION_MODE_VECTOR												16	// Direct 	(Speed set directly by user through their position commands (Per axis))
#define	MOTION_MODE_CNCB												17	// Direct 	(Speed set directly by user through their position commands (Per axis))
#define	MOTION_MODE_SPLINE_BUFFER										18	// Direct 	(Speed set directly by user through their position commands (Per axis))
#define	MOTION_MODE_FIFO_POSITION_TRACKING								19
#define	LAST_MOTION_MODE												19	// Must be equal to the last motion mode available as it affects the range of MotionMode in Params.h
*/


